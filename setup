#!/bin/sh

set -xeu

git_dir=~/.local/share/dotfiles/git
GIT_DIR=$(git rev-parse --absolute-git-dir 2>/dev/null || echo $git_dir)
export GIT_DIR

if ! git config --local core.worktree >/dev/null; then
	if [ "${GIT_DIR:-}" != $git_dir ]; then
		mkdir -p "$(dirname $git_dir)"
		mv "$GIT_DIR" $git_dir
		GIT_DIR=$git_dir
	fi

	git config core.worktree ~
	git config include.path ~/.config/dotfiles/.gitconfig

	if [ -t 2 ]; then
		git diff --diff-filter=D --name-only -z | git -C ~ checkout --pathspec-from-file=- --pathspec-file-nul
	else
		: "Clobbering all dotfiles"
		git checkout @ ~
	fi
fi
unset GIT_DIR

ln -fs ~/.config/git/hooks/* ~/.config/git/template/hooks

has() { command -v "$1" >/dev/null; }

if has chflags; then
	hide() { chflags -v hidden "$@" 2>/dev/null ||:; }
else
	hide() { for f do grep -sqxF "$f" .hidden || echo "$f" >> .hidden; done; }
fi

cd && hide pkg src setup tmp

os=$(uname -s)
os() { [ "$os" = "$1" ]; }
manager() { [ "$manager" = "$1" ]; }
use_manager() {
	manager=$1
	shift
	eval "install() {
		xargs sudo ${*-true}
	}"
}

if os Darwin; then
	if has brew; then
		HOMEBREW_NO_ENV_HINTS=1 brew bundle --file ~/.config/dotfiles/Brewfile
	else
		open https://brew.sh
		exit 1
	fi

elif has pacman; then
	use_manager Arch pacman -Sy --noconfirm --needed

elif has apt-get; then
	sudo apt-get update --option DPkg::Lock::Timeout=60
	use_manager APT apt-get install --option DPkg::Lock::Timeout=60 --yes

elif has brew; then
	use_manager Homebrew

fi

if ! os Darwin; then
	if ! has ruby; then
		if manager Arch; then
			echo ruby-stdlib
		else
			echo ruby
		fi | install
	fi
	ruby -r ~/.local/share/dotfiles/package -e "puts Package.$manager" | install
fi

if os Darwin && ! test -f /etc/pam.d/sudo_local; then
	sudo sh -c "echo 'auth       sufficient     pam_tid.so' >/etc/pam.d/sudo_local"
	sudo -k
	tccutil reset All com.apple.Terminal
fi
